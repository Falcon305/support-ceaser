# Pick a model with a "provider:model" spec (see src/provider.ts) and set the matching key.

# anthropic:claude-sonnet-4
ANTHROPIC_API_KEY=

# openai:gpt-4o
OPENAI_API_KEY=

# deepseek:deepseek-chat
DEEPSEEK_API_KEY=

# compatible:<model> — Qwen, Moonshot/Kimi, Zhipu/GLM, Groq, OpenRouter, etc.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ollama:<model> — local, free, no key. Just run ollama. Override the host if needed:
# OLLAMA_BASE_URL=http://localhost:11434/v1
